# AcuiCal Server — Variables de entorno

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (service_role key para seed)

# Base de datos (Prisma usa DATABASE_URL)
# La obtienes de Supabase: Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres

# JWT (lo firma Supabase automáticamente, pero para lógica extra)
JWT_SECRET=poner-un-secreto-fuerte-aqui

# Puerto del servidor
PORT=3001
