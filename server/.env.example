# AcuiCal Server — Variables de entorno

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Base de datos (Prisma usa DATABASE_URL)
# La obtienes de Supabase: Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres

# JWT (lo firma Supabase automáticamente, pero para lógica extra)
JWT_SECRET=poner-un-secreto-fuerte-aqui

# Puerto del servidor
PORT=3001

# ONVO Pay (Costa Rica)
# Obtener en https://onvopay.com → Dashboard → Developers
ONVO_SECRET_KEY=onvo_test_secret_key_...
ONVO_WEBHOOK_SECRET=webhook_secret_...

# IDs de precios creados en ONVO Dashboard → Products
# Crear productos "AcuiCal Pro" ($29/mes) y "AcuiCal Enterprise" ($99/mes)
ONVO_PRICE_PRO_MONTHLY=price_id_pro
ONVO_PRICE_ENTERPRISE_MONTHLY=price_id_enterprise

# Supabase Service Role (para actualizar metadata de usuario desde webhooks)
# Obtener en Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
